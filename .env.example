# Base de Datos
POSTGRES_URL=postgresql://user:password@host/database?sslmode=require

# Slack OAuth Credentials
# Obtén estos valores en: https://api.slack.com/apps
SLACK_CLIENT_ID=your_slack_client_id_here
SLACK_CLIENT_SECRET=your_slack_client_secret_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Slack OAuth Redirect URI
# Local: http://localhost:3002/api/slack/oauth/callback
# Producción: https://your-domain.com/api/slack/oauth/callback
SLACK_REDIRECT_URI=http://localhost:3002/api/slack/oauth/callback

# OpenAI API (para GPT-4, GPT-3.5)
# Obtén tu API key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API (para Claude)
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
